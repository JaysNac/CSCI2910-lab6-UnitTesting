@page "/users"
@rendermode InteractiveServer
@using Lab5LibraryApp.Models
@using Lab5LibraryApp.Services
@inject ILibraryService LibraryService

<h3>User Management</h3>

<div class="mb-3">
    <input @bind="newUser.Name" placeholder="Name" class="form-control mb-2" />
    <input @bind="newUser.Email" placeholder="Email" class="form-control mb-2" />
    <button class="btn btn-primary" @onclick="AddUser">Add User</button>
</div>

@if (!string.IsNullOrEmpty(message))
{
    <p>@message</p>
}

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>
                    <button class="btn btn-warning btn-sm me-2" @onclick="() => StartEdit(user)">Edit</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteUser(user.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (editingUser != null)
{
    <h4>Edit User</h4>

    <div class="mb-3">
        <input @bind="editingUser.Name" class="form-control mb-2" />
        <input @bind="editingUser.Email" class="form-control mb-2" />
        <button class="btn btn-success me-2" @onclick="SaveEdit">Save</button>
        <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
    </div>
}

@code {
    private List<User> users = new();
    private User newUser = new();
    private User? editingUser;
    private string message = "";

    protected override void OnInitialized()
    {
        LoadUsers();
    }

    private void LoadUsers()
    {
        users = LibraryService.GetUsers().ToList();
    }

    private void AddUser()
    {
        if (string.IsNullOrWhiteSpace(newUser.Name) ||
            string.IsNullOrWhiteSpace(newUser.Email))
        {
            message = "Please fill in all user fields.";
            return;
        }

        LibraryService.AddUser(new User
        {
            Name = newUser.Name,
            Email = newUser.Email
        });

        newUser = new User();
        message = "User added successfully.";
        LoadUsers();
    }

    private void DeleteUser(int id)
    {
        LibraryService.DeleteUser(id);
        message = "User deleted successfully.";
        LoadUsers();
    }

    private void StartEdit(User user)
    {
        editingUser = new User
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email
        };
    }

    private void SaveEdit()
    {
        if (editingUser == null)
            return;

        if (string.IsNullOrWhiteSpace(editingUser.Name) ||
            string.IsNullOrWhiteSpace(editingUser.Email))
        {
            message = "Please fill in all edit fields.";
            return;
        }

        LibraryService.EditUser(editingUser);
        editingUser = null;
        message = "User updated successfully.";
        LoadUsers();
    }

    private void CancelEdit()
    {
        editingUser = null;
        message = "";
    }
}